rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if request.auth.uid == schoolId;
    }

    match /teachers/{teacherId} {
      allow read: if resource.data.isProfilePublic == true || request.auth.uid == teacherId;
      allow write: if request.auth.uid == teacherId;

      match /endorsements/{endId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid != teacherId;
      }
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.schoolId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.schoolId;
    }

    match /applications/{appId} {
      allow create: if request.auth.uid == request.resource.data.teacherId;
      allow read: if request.auth.uid == resource.data.teacherId
                  || request.auth.uid == resource.data.schoolId;
      allow update: if request.auth.uid == resource.data.schoolId
                    || request.auth.uid == resource.data.teacherId;
    }

    match /notifications/{notifId} {
      allow read, update: if request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /savedJobs/{docId} {
      allow read, write: if request.auth.uid == resource.data.teacherId
                         || request.auth.uid == request.resource.data.teacherId;
    }

    match /conversations/{convId} {
      allow read, write: if request.auth.uid in resource.data.participants
                         || request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                      && request.auth.uid == request.resource.data.senderId;
        allow update: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
